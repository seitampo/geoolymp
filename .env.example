# PostgreSQL (Neon). DATABASE_URL — pooled-соединение для приложения.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"
# DIRECT_URL — прямое соединение (без -pooler) для миграций Prisma.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"
# Секрет для подписи сессионных cookie. В продакшене задать обязательно.
AUTH_SECRET="change-this-secret-in-production"
# Код-приглашение для регистрации учителем (раздаётся доверенным учителям).
# Если не задан — регистрация учителем полностью закрыта.
TEACHER_INVITE_CODE="your-teacher-invite-code"

# Cloudflare R2 (S3-совместимое хранилище загруженных файлов).
R2_ACCOUNT_ID="cloudflare-account-id"
R2_ACCESS_KEY_ID="r2-access-key-id"
R2_SECRET_ACCESS_KEY="r2-secret-access-key"
R2_BUCKET_NAME="ваш-bucket"
