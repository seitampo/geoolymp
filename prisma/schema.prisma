generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  TEACHER
  STUDENT
}

enum SubmissionStatus {
  PENDING
  REVIEWED
}

enum MaterialType {
  TEXT
  PDF
  DOCX
  PPTX
  IMAGE
  LINK
  ZIP
}

enum TaskType {
  TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  IMAGE_UPLOAD
  FILE_UPLOAD
}

enum OlympiadLevel {
  SCHOOL
  REGIONAL
  REPUBLICAN
  INTERNATIONAL
}

model User {
  id               Int               @id @default(autoincrement())
  name             String
  email            String            @unique
  password         String
  role             Role
  groups           Group[]           @relation("TeacherGroups")
  memberships      Membership[]
  submissions      Submission[]
  materialViews    MaterialView[]
  trainingAttempts TrainingAttempt[]
}

model Group {
  id          Int          @id @default(autoincrement())
  name        String
  description String
  inviteCode  String       @unique
  teacherId   Int
  teacher     User         @relation("TeacherGroups", fields: [teacherId], references: [id], onDelete: Cascade)
  memberships Membership[]
  materials   Material[]
  tasks       Task[]
  taskSets    TaskSet[]

  @@index([teacherId])
}

model Membership {
  id      Int   @id @default(autoincrement())
  userId  Int
  groupId Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Material {
  id               Int            @id @default(autoincrement())
  groupId          Int
  title            String
  description      String
  type             MaterialType   @default(LINK)
  url              String?
  filePath         String?
  originalFileName String?
  uploadedAt       DateTime       @default(now())
  group            Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  views            MaterialView[]

  @@index([groupId])
}

// Отметка «ученик изучил материал» — для полосок прогресса на странице группы.
// Создаётся при открытии/скачивании материала или явной отметкой (текстовые материалы).
model MaterialView {
  id         Int      @id @default(autoincrement())
  materialId Int
  userId     Int
  viewedAt   DateTime @default(now())
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([materialId, userId])
  @@index([userId])
}

model Task {
  id                Int          @id @default(autoincrement())
  groupId           Int
  title             String
  description       String
  maxScore          Int
  type              TaskType     @default(TEXT)
  options           String?
  correctAnswer     String?
  imagePath         String?
  originalImageName String?
  opensAt           DateTime?
  dueAt             DateTime?
  // Черновики: ученики видят задачу, только когда isPublished = true либо
  // наступило запланированное время публикации publishAt (проверка на сервере).
  isPublished       Boolean      @default(true)
  publishAt         DateTime?
  // Классификация для библиотеки и будущего конструктора олимпиад.
  grade             Int? // класс, 7–11
  olympiadLevel     OlympiadLevel?
  difficulty        Int? // сложность, 1–5
  // Разбор решения: текст и/или файл (PDF/картинка). Ученик видит после проверки
  // своего решения (submissions/[id] REVIEWED), доступ контролируется на сервере.
  explanationText     String?
  explanationFilePath String?
  explanationFileName String?
  group             Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  submissions       Submission[]
  setItems          TaskSetItem[]
  trainingAnswers   TrainingAnswer[]

  @@index([groupId])
}

// Тематическая подборка задач группы («Климат — 20 задач»).
model TaskSet {
  id          Int           @id @default(autoincrement())
  groupId     Int
  title       String
  description String
  // Режим тренировки: лимит времени в минутах. null — обычная подборка.
  // У тренировочной подборки ученик не видит задачи заранее — только через попытку.
  trainingMinutes Int?
  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  items       TaskSetItem[]
  attempts    TrainingAttempt[]

  @@index([groupId])
}

// Попытка тренировки: одна на пару подборка+ученик («одна попытка»).
model TrainingAttempt {
  id         Int              @id @default(autoincrement())
  setId      Int
  studentId  Int
  startedAt  DateTime         @default(now())
  // Дедлайн фиксируется при старте; сервер сверяется с ним при каждом запросе.
  expiresAt  DateTime
  finishedAt DateTime?
  set        TaskSet          @relation(fields: [setId], references: [id], onDelete: Cascade)
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers    TrainingAnswer[]

  @@unique([setId, studentId])
  @@index([studentId])
}

model TrainingAnswer {
  id        Int             @id @default(autoincrement())
  attemptId Int
  taskId    Int
  answer    String
  // Заполняются при завершении попытки: null — тип без автопроверки (текстовый).
  isCorrect Boolean?
  score     Int             @default(0)
  attempt   TrainingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([attemptId, taskId])
  @@index([taskId])
}

model TaskSetItem {
  id       Int     @id @default(autoincrement())
  setId    Int
  taskId   Int
  // Порядок решения внутри подборки (по порядку добавления).
  position Int
  set      TaskSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([setId, taskId])
  @@index([taskId])
}

model Submission {
  id               Int              @id @default(autoincrement())
  taskId           Int
  studentId        Int
  answer           String
  filePath         String?
  originalFileName String?
  status           SubmissionStatus @default(PENDING)
  task             Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student          User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  review           Review?

  @@unique([taskId, studentId])
  @@index([studentId])
}

model Review {
  id              Int        @id @default(autoincrement())
  submissionId    Int        @unique
  score           Int
  feedback        String
  // Когда ученик увидел результат. null — показываем пометку «Новый результат»;
  // при изменении оценки учителем сбрасывается, чтобы пометка появилась снова.
  seenByStudentAt DateTime?
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}
